# Database connection string
# For Docker: postgres://tracker_user:tracker_password@postgres:5432/issuetracker
# For local: postgres://tracker_user:tracker_password@localhost:5432/issuetracker
dbConnStr=postgres://tracker_user:tracker_password@localhost:5432/issuetracker

# Server port
PORT=3001

# JWT secret key for token signing (change in production!)
jwtSecret=your-secret-key-change-in-production

# Allowed origins for CORS (comma-separated)
allowedOrigins=http://localhost:3000,http://192.168.9.227:3000